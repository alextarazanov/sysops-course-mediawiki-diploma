{% set wikimedia_ips = [] %}
{% for item in groups['wikimedia'] %}
    {%- set _ = wikimedia_ips.append(hostvars[item]['ansible_host']) %}
{% endfor %}
upstream wikimedia.backend {
{% for wikimedia_ip in wikimedia_ips %}
    server {{ wikimedia_ip }};
{% endfor %}
}

server {
    listen 80;
    proxy_connect_timeout 2s;

    location / {
        proxy_pass http://wikimedia.backend;
        proxy_set_header Host $host;
    }
}
